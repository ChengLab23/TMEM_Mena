### function to generate and save multiple km plots
```{r}

generate_km_plots <- function(mydata, primary_var, file_tag) {
  
  km.ddfs <- kmf(primary_var, mydata, "tddfs", "ddfs", "Distant Disease Free Survival", "Without truncation")
  km.ddfs.5ys <- kmf(primary_var, mydata, "tddfs_5ys", "ddfs_5ys", "Distant Disease Free Survival", "With 5-year truncation")
  
  km.dfs <- kmf(primary_var, mydata, "tdfs", "dfs", "Disease Free Survival", "Without truncation")
  km.dfs.5ys <- kmf(primary_var, mydata, "tdfs_5ys", "dfs_5ys", "Disease Free Survival", "With 5-year truncation")

  cohort_label <- dplyr::recode(
    file_tag,
    "all_sample" = "all_patients",
    "her2_er_subgroup" = "er_her2",
    .default = file_tag
  )
  marker_label <- dplyr::recode(
    primary_var,
    "tmem_tertile" = "tmem_tertile",
    "mena_calc_tertile" = "menacalc_tertile",
    "mena_inv_tertile" = "menainv_tertile",
    .default = primary_var
  )

  pdf(file.path(km_dir, paste0(cohort_label, "_", marker_label, ".pdf")), width = 10, height = 5)

  arrange_ggsurvplots(list(km.ddfs, km.ddfs.5ys), ncol = 2, nrow = 1)
  arrange_ggsurvplots(list(km.dfs, km.dfs.5ys), ncol = 2, nrow = 1)

  dev.off()
}
