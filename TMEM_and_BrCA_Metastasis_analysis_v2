#KM 
### function to produce one km plot

```{r}
kmf <- function(my_var,mydata, my_time, my_event, my_title, my_subtitle) {
  if (my_var == "tmem_tertile"){
    my_legend = c("Low", "Mid", "High")
    my_legend_title = "TMEM Doorway Score"
  } else if (my_var == "mena_calc_tertile"){
    my_legend = c("Low", "Mid", "High")
    my_legend_title = expression(Mena^{calc}~"Score")
  } else if (my_var == "mena_inv_tertile"){
    my_legend = c("Low", "Mid", "High")
    my_legend_title = expression(Mena^{INV}~"Score")
  } 
  
  # Create the formula using reformulate() for better reliability
  surv_formula <- reformulate(my_var, 
                            response = paste0("Surv(", my_time, ", ", my_event, ")"))
  
  
  #fit the model to extract p value
  #fit <- survival::survfit(surv_formula, data = mydata)
#fit$formula <- surv_formula

sd <- survival::survdiff(surv_formula, data = mydata)
  pval_raw <- 1 - stats::pchisq(sd$chisq, df = length(sd$n) - 1)
  
  pval_label <- ifelse(is.na(pval_raw), "", ifelse(pval_raw < 0.001, "P < 0.001", ifelse(pval_raw < 0.01, paste0("P = ", sprintf("%.3f", pval_raw)), paste0("P = ", sprintf("%.2f", pval_raw)))))


  # Fit the model with explicit data evaluation for plot
  fit <- eval(bquote(
    survfit(.(surv_formula), data = mydata,)
  ))
  
  # Create the plot
  p1 <- ggsurvplot(
    fit,
    data = mydata,
    title = paste("Kaplan-Meier Curve of", my_title),
    subtitle = my_subtitle,
    legend.title = my_legend_title,
    legend.labs = my_legend,
    font.title = c(12, "bold", "black"),
    font.subtitle = c(10, "bold.italic", "black"),
    font.x = c(10, "italic", "black"),
    font.y = c(10, "italic", "black"),
    fontsize = 3,
    font.tickslab = c(9, "plain", "black"),
    risk.table.height = 0.25,
    pval = pval_label, 
    conf.int = FALSE,
    risk.table = TRUE,
    risk.table.col = "strata",
    linetype = "strata",
    test.for.trend = FALSE,
    xlab = "Time (years)",
    ylab = "Survival",
    risk.table.y.text = FALSE,
    font.legend = list(size = 10, color = "black"),
    xscale = "m_y",          # months → years
    break.time.by = 12,      # tick every year
    ggtheme = theme_classic2(base_size = 10)
  )
  
  p1$table <- p1$table + 
    theme(plot.title = element_text(size = 9))
  
  return(p1)
}

