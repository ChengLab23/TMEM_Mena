## create time variable: ddfs and DFS, OS
```{r}

# OS: Overall survival is defined as the time from curative surgery to death from
# any cause. The OS variables are tos (time) and os (event).

# DFS: Disease-free survival events include local, regional, or distant recurrence;
# contralateral breast cancer; non-breast second primary cancers; and death before
# recurrence. Patients are censored at the end of follow-up
# or at loss to follow-up.


# DDFS: Distant disease-free survival focuses on distant metastasis. Events other
# than distant recurrence are treated as censoring events.

# Variables ending in "_5ys" indicate outcomes administratively truncated at 5 years.
# For these variables, follow-up time is capped at 60 months; events occurring after
# 60 months are treated as censored at 60 months.

df = df %>% mutate(
  
#outcome(months):
  locrec = as.numeric(locrec),#Had Local Recurrence 
  tlocrec = as.numeric(tlocrec),#Time to First local Recurrence
  
  regrec= as.numeric(regrec),#Had Regional Recurrence 
  treg_rec = as.numeric(treg_rec),#Time to First Regional Recurrence
  
  disrec = as.numeric(disrec),#Had Distant Recurrence 
  tdis_rec = as.numeric(tdis_rec),#Time to First Distant Recurrence 
  
  secpri = as.numeric(secpri),#Had Second Primary Cancer/ Including Contralateral BC
  tp2 = as.numeric(tp2),#Time to First Second Primary Cancer 
  
  death = as.numeric(death),
  tlfup = as.numeric(tlfup)#Time to Death or Last Follow-up
)

# truncation
df = df %>% rowwise() %>% 
   mutate(
  #OS
     os = death,
    tos = tlfup,
    
   os_5ys = ifelse(tos > 60 , 0, os),
   tos_5ys = ifelse(tos > 60 ,60 , tos), 
   
  #DDFS
  ddfs = disrec,
  tddfs = ifelse(ddfs==1, tdis_rec, tlfup),
  
  ddfs_5ys = ifelse(tddfs > 60, 0, ddfs),
  tddfs_5ys = ifelse(tddfs > 60, 60, tddfs),
  
  #DFS
    dfs = ifelse(locrec==0 & regrec==0 & disrec==0 & secpri==0 & death==0, 0,1),
    tdfs = min(tlocrec, treg_rec, tdis_rec, tp2, tlfup, na.rm = T),
    
    dfs_5ys = ifelse(tdfs > 60 , 0, dfs),
    tdfs_5ys = ifelse(tdfs > 60 ,60 , tdfs)
    
    ) %>% ungroup()
```

