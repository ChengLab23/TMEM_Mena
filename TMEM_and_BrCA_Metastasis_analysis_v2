## build COX function
```{r}
#Centralized data switch for time-varying models
get_cox_data <- function(outcome_name, interaction, data) {
  if (interaction != "time_vary") return(data)

  switch(
    outcome_name,
    OS       = cox_os,
    DDFS     = cox_ddfs,
    DFS      = cox_dfs,
    OS_5YS   = cox_os_5ys,
    DDFS_5YS = cox_ddfs_5ys,
    DFS_5YS  = cox_dfs_5ys,
    data
  )
}

#formular builder
build_cox_formula <- function(time, event, mymarker, interaction, covars) {
  as.formula(
    paste0(
      "Surv(", time, ", ", event, ") ~ ",
      mymarker,
      if (interaction == "time_vary") ":strata(tgroup)" else "",
      covars
    )
  )
}

#generate table
make_cox_table <- function(data, mymarker, covars,interaction = "NO") {

  tbls <- purrr::imap(
    outcomes,
    function(outcome, outcome_name) {

      f <- build_cox_formula(
        time  = outcome$time,
        event = outcome$event,
        mymarker = mymarker,
        interaction = interaction,
        covars = covars
      )

      d <- get_cox_data(outcome_name, interaction, data)
      
      # --- capture warning + print which model caused it ---
      fit <- withCallingHandlers(
        coxph(f, data = d, ties = "breslow", model = TRUE, x = TRUE, y = TRUE),
        warning = function(w) {
          message("\n⚠️ Cox warning in outcome: ", outcome_name,
                  "  [", outcome$outcome_label, "]")
          message("Formula: ", deparse(f))
          message("Warning: ", conditionMessage(w), "\n")
          invokeRestart("muffleWarning")
        }
      )
 
      tbl_regression(
        fit,
        label = mylabel,
        exponentiate = TRUE,
        pvalue_fun = format_p
      ) %>%
        add_global_p(keep = TRUE) %>%
        bold_p(t = 0.05) %>%
        bold_labels() %>%
        italicize_levels()
    }
  )

  ft = tbl_merge(
    tbls = tbls,
    tab_spanner = paste0("**", purrr::map_chr(outcomes, "outcome_label"), "**")
  ) 
  ft <- ft %>%
  modify_table_body(
    ~ .x %>%
      dplyr::mutate(order_flag = if_else(grepl(":", variable), 0, 1)) %>%
      dplyr::arrange(order_flag) %>%
      dplyr::select(-order_flag)
  )
  
  ft = ft %>%
    as_flex_table() %>%
    set_table_properties(layout = "autofit") %>%
    padding(
      padding.top = 0, padding.bottom = 0,
      padding.left = 1, padding.right = 1
    ) %>% autofit() %>% vline(j = c(4,7,10), border = fp_border(color = "black", width = 1))
# highlight p value
  for (j in c(4,7,10,13)) {

    pvals <- suppressWarnings(as.numeric(ft$body$dataset[[j]]))# <- force numeric, other wise >0.99 will be red
  sig_rows <- which(
  (!is.na(pvals) & pvals < 0.05) |
  ft$body$dataset[[j]] == "<0.001"
)

  ft <- ft %>%
    color(i = sig_rows, j = j, color = "red", part = "body")
}
  #change covariate to grey
  char_col <- names(ft$body$dataset)[1]

  # find the row index where "age" appears
  age_row <- which(str_detect(ft$body$dataset[[char_col]], "^Age$"))

  # rows to grey = age row to last row
  rows_to_grey <- age_row:nrow(ft$body$dataset)

  # apply grey color
  ft = ft %>%
    color(i = rows_to_grey, color = "grey60", part = "body")
  
  ft = ft %>% add_header_lines("Adjusted Cox regression models") %>% bold(i = 1, part = "header")
  
}


```

## build unadjusted COX function
```{r}
make_uni_cox_table <- function(data, mymarker) {

  tbls <- purrr::imap(
    outcomes,
    function(outcome, outcome_name) {

      tbl_uvregression(
        data = data,
        hide_n = TRUE,
        method = coxph,
        y = Surv(!!sym(outcome$time), !!sym(outcome$event)),
        include = all_of(mymarker),
        exponentiate = TRUE,
        pvalue_fun = format_p
      ) %>%
        add_global_p(keep = TRUE) %>%
        bold_p(t = 0.05) %>%
        bold_labels() %>%
        italicize_levels()
    }
  )

  ft <- tbl_merge(
    tbls = tbls,
    tab_spanner = paste0("**", purrr::map_chr(outcomes, "outcome_label"), "**")
  )

  ft = ft %>%
    as_flex_table() %>%
    set_table_properties(layout = "autofit") %>%
    padding(
      padding.top = 0, padding.bottom = 0,
      padding.left = 1, padding.right = 1
    ) %>%
    autofit() %>%
    vline(j = c(4, 7, 10), border = fp_border(color = "black", width = 1))

  for (j in c(4, 7, 10, 13)) {
    pvals <- suppressWarnings(as.numeric(ft$body$dataset[[j]]))
    sig_rows <- which(
      (!is.na(pvals) & pvals < 0.05) |
        ft$body$dataset[[j]] == "<0.001"
    )

    ft <- ft %>%
      color(i = sig_rows, j = j, color = "red", part = "body")
  }

  ft %>%
    add_header_lines("Unadjusted Cox regression models") %>%
    bold(i = 1, part = "header")
}
```


## creat event table
```{r}
make_event_table <- function(data, marker, outcomes){

  purrr::imap_dfr(
    outcomes,
    function(outcome, outcome_name){

      data %>%
        dplyr::filter(!is.na(.data[[marker]])) %>%   # remove NA levels
        dplyr::group_by(.data[[marker]]) %>%
        dplyr::reframe(
          Events = sum(.data[[outcome$event]] == 1, na.rm = TRUE),
          N = dplyr::n()
        ) %>%
        dplyr::mutate(
          outcome = outcome$outcome_label,
          value = paste0(Events, " / ", N)
        ) %>%
        dplyr::select(!!marker := all_of(marker), outcome, value)
    }
  ) %>%
  tidyr::pivot_wider(
    names_from = outcome,
    values_from = value
  )
  
}
